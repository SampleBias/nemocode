# Local OpenAI-compatible llama.cpp server (started by ./start-nemo.sh)
NEMO_BASE_URL=http://127.0.0.1:8080/v1
NEMO_MODEL=Nemotron-3-Nano-4B-Coding-Agent-Q4_K_M
NEMO_API_KEY=local
NEMO_MAX_TOKENS=4096
NEMO_TOOL_ROUNDS=8
# Approximate prompt token budget kept across sticky history compaction
NEMO_CONTEXT_BUDGET=12000
# Abort if the model SSE stream stalls with no chunks (seconds). 0 = wait forever.
NEMO_SSE_IDLE_TIMEOUT_SECS=300

# Optional launcher overrides for ./start-nemo.sh
# NEMO_MODEL_PATH=/absolute/path/to/Nemotron-3-Nano-4B-Coding-Agent-Q4_K_M.gguf
# NEMO_MODELS_DIR=./models
# NEMO_HOST=127.0.0.1
# NEMO_PORT=8080
# NEMO_CTX=16384
# NEMO_GPU_LAYERS=99
# NEMO_THREADS=8
# NEMO_PARALLEL=1
# NEMO_FLASH_ATTN=on
# NEMO_BATCH=2048
# NEMO_UBATCH=512
# NEMO_CACHE_TYPE_K=q8_0
# NEMO_CACHE_TYPE_V=q8_0
# NEMO_MLOCK=1
# NEMO_LLAMA_SERVER=/path/to/llama-server
# NEMO_LLAMA_BACKEND=cpu
# NEMO_LLAMA_RELEASE=b10043
# NEMO_VENDOR_DIR=./.vendor/llama.cpp
